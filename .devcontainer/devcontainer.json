{
  "name": "Oh My OpenAgent Secure Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "mounts": [
    "source=omo-dev-config,target=/home/vscode/.config,type=volume",
    "source=omo-dev-cache,target=/home/vscode/.cache,type=volume"
  ],
  "runArgs": ["--security-opt=no-new-privileges", "--pids-limit=512"],
  "remoteEnv": {
    "PATH": "/home/vscode/.opencode/bin:/home/vscode/.bun/bin:/home/vscode/.local/bin:${containerEnv:PATH}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },
  "containerEnv": {
    "OMO_DISABLE_POSTHOG": "1",
    "OMO_SEND_ANONYMOUS_TELEMETRY": "0",
    "XDG_CACHE_HOME": "/tmp/vscode-cache"
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "alexkrechik.cucumberautocomplete",
        "cstrap.flask-snippets",
        "yzhang.markdown-all-in-one",
        "bierner.github-markdown-preview",
        "hnw.vscode-auto-open-markdown-preview",
        "DavidAnson.vscode-markdownlint",
        "donjayamanne.githistory",
        "GitHub.vscode-pull-request-github",
        "hbenl.vscode-test-explorer",
        "njpwerner.autodocstring",
        "alexcvzz.vscode-sqlite",
        "ms-toolsai.jupyter",
        "mechatroner.rainbow-csv",
        "redhat.vscode-yaml",
        "snyk-security.snyk-vulnerability-scanner"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "security.workspace.trust.enabled": true,
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/venv/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.autopep8Path": "/usr/local/py-utils/bin/autopep8",
        "python.formatting.blackPath": "/usr/local/py-utils/bin/black",
        "python.formatting.yapfPath": "/usr/local/py-utils/bin/yapf",
        "python.linting.banditPath": "/usr/local/py-utils/bin/bandit",
        "python.linting.flake8Path": "/usr/local/py-utils/bin/flake8",
        "python.linting.mypyPath": "/usr/local/py-utils/bin/mypy",
        "python.linting.pycodestylePath": "/usr/local/py-utils/bin/pycodestyle",
        "python.linting.pydocstylePath": "/usr/local/py-utils/bin/pydocstyle",
        "python.linting.pylintPath": "/usr/local/py-utils/bin/pylint",
        "python.linting.pylintArgs": ["--disable=C0111"]
      }
    }
  },
  "postCreateCommand": "bash -c 'export PATH=/home/vscode/.opencode/bin:/home/vscode/.bun/bin:/home/vscode/.local/bin:$PATH && uv venv venv && ([ -f requirements.txt ] && uv pip install -r requirements.txt && uv pip install pip-audit && pip-audit || true) && OMO_INSTALL_OPENCODE_IF_MISSING=1 bash scripts/bootstrap-oh-my-openagent.sh || true && mkdir -p ~/.config/opencode .opencode && cp .devcontainer/oh-my-openagent.json ~/.config/opencode/oh-my-openagent.json && cp .devcontainer/oh-my-openagent.json .opencode/oh-my-openagent.json && opencode models --refresh || true && echo \'source /workspaces/openagent-devcontainer/venv/bin/activate\' >> ~/.bashrc'",
  "features": {
    "ghcr.io/devcontainers/features/github-cli": { "version": "latest" }
  }
}
